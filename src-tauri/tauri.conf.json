{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llama-launcher",
  "version": "0.2.0",
  "identifier": "com.optidoc.llama-launcher",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cross-env TAURI_BUILD=true bun run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "llama-launcher",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "focus": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: filesystem: ws: wss: http: https: tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; style-src 'self' 'unsafe-inline' data: blob:; img-src 'self' data: blob: filesystem: http: https:; font-src 'self' data: blob:; connect-src 'self' ws: wss: http: https: tauri:; worker-src 'self' blob: data:;"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/OptiDoc/llama-launcher/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1MkU0Q0Y3QjY0M0Y5QkYKUldQMHRnVWg0aVpvSjFtY2RZeE9aN0NJQ0R3bHQ2N0J5Mm4vNzZjT01mQ0d6WU1JQQ=="
    }
  }
}
